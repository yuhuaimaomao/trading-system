# Trading System - 环境变量配置
# 复制此文件为 .env 并填写实际值

# ===== API Keys =====
DASHSCOPE_API_KEY=sk-xxx
DASHSCOPE_ENDPOINT=https://dashscope.aliyuncs.com/api/v1/services/aigc/text-generation/generation
DASHSCOPE_MODEL=qwen-plus
DASHSCOPE_ANALYSIS_MODEL=qwen3.6-plus

# ===== DeepSeek =====
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_ENDPOINT=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# ===== Telegram =====
TELEGRAM_CHAT_ID=-xxx
TELEGRAM_REPORT_BOT_TOKEN=xxx
TELEGRAM_REPORT_CHAT_ID=-xxx

# ===== QMT =====
QMT_HOST=192.168.1.33
QMT_PORT=5000

# ===== 代理 =====
PROXY_ENABLED=false

# ===== 交易 =====
ACCOUNT_MODE=manual
